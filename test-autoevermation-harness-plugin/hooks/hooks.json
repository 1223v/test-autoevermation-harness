{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.cjs", "--ensure-only"],
            "timeout": 600
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.cjs", "script", "${CLAUDE_PLUGIN_ROOT}/scripts/guard-network.py"],
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Read|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.cjs", "script", "${CLAUDE_PLUGIN_ROOT}/scripts/guard-read.py"],
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.cjs", "script", "${CLAUDE_PLUGIN_ROOT}/scripts/guard-gate-artifacts.py"],
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/launch.cjs", "script", "${CLAUDE_PLUGIN_ROOT}/scripts/redact-secrets.py", "--mode", "warn"],
            "timeout": 45
          }
        ]
      }
    ]
  }
}
